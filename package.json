{
  "name": "plutoploy-gh-bot",
  "version": "1.0.0",
  "private": true,
  "description": "plutoploy a easier way to devops",
  "author": "Plutoploy",
  "license": "ISC license",
  "homepage": "https://github.com/plutoploy/plutoploy-gh-bot",
  "keywords": [
    "probot",
